ing models — leads naturally into dataset attribution questions.","id":"tmpl:1772573350424","createdAt":1772573350424,"text":"Live models with Sharpe below $threshold","cypher":"MATCH path = (:Dataset)-[:FEEDS]->(:FeaturePipeline)\n             -[:GENERATES]->(:Feature)\n             -[:USED_IN]->(m:Model)\nWHERE m.status = 'Live'\n  AND m.live_sharpe < toFloat($threshold)\nRETURN path","isUpdateQuery":false,"isWriteTransactionChecked":false,"params":[{"name":"$threshold","dataType":"Float","suggestions":"property","cypher":null,"suggestionLabel":"Model","suggestionProp":"live_sharpe","suggestionBoolean":false,"collapsed":false,"id":"ae78f821-2c1d-4ba9-891d-a06a43527798"}],"hasCypherErrors":false},{"name":"Good for compliance conversations.","id":"tmpl:1772573258983","createdAt":1772573258983,"text":"Datasets with MNPI risk above $score","cypher":"MATCH path = (:DataVendor)-[:PROVIDES]->(d:Dataset)\n             -[:FEEDS]->(:FeaturePipeline)\n             -[:GENERATES]->(:Feature)\n             -[:USED_IN]->(m:Model)\nWHERE d.mnpi_risk_score >= toFloat($score)\n  AND m.status = 'Live'\nRETURN path","isUpdateQuery":false,"isWriteTransactionChecked":false,"params":[{"name":"$score","dataType":"Float","suggestions":"property","cypher":null,"suggestionLabel":"Dataset","suggestionProp":"mnpi_risk_score","suggestionBoolean":false,"collapsed":false}],"hasCypherErrors":false},{"name":"great for \"what do I need to decide on before Q2?\"","id":"tmpl:1772572873148","createdAt":1772572873148,"text":"Renewals before $date","cypher":"MATCH path = (v:DataVendor)-[prov:PROVIDES]->(d:Dataset)\nWHERE date(prov.renewal_date) <= date($date)\n  AND date(prov.renewal_date) >= date('2025-01-01')\nRETURN path","isUpdateQuery":false,"isWriteTransactionChecked":false,"params":[{"name":"$date","dataType":"String","suggestions":"none","cypher":null,"suggestionLabel":null,"suggestionProp":null,"suggestionBoolean":false,"collapsed":false}],"hasCypherErrors":false}],"type":"STANDARD_PERSPECTIVE"